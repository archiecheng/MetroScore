// Connection URL is configured in prisma.config.ts (Prisma 7 requirement).
datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ReportStatus {
  DRAFT
  PENDING_PAYMENT
  PAID
  DELIVERED
  FAILED
}

// ---------------------------------------------------------------------------
// Models
// ---------------------------------------------------------------------------

model City {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  state     String
  metroName String?
  county    String?
  latitude  Float?
  longitude Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  metrics    CityMetric[]
  reportsAsA Report[]     @relation("CityA")
  reportsAsB Report[]     @relation("CityB")
}

model CityMetric {
  id                   String   @id @default(cuid())
  cityId               String
  city                 City     @relation(fields: [cityId], references: [id], onDelete: Cascade)
  year                 Int

  population           Int?
  medianHomeValue      Float?
  medianRent           Float?
  medianHouseholdIncome Float?
  unemploymentRate     Float?
  housePriceIndex      Float?
  rentToPriceRatio     Float?
  populationGrowthRate Float?
  homePriceGrowthRate  Float?

  sourceName           String?
  sourceUrl            String?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([cityId, year])
}

model Report {
  id              String       @id @default(cuid())
  cityAId         String
  cityBId         String
  cityA           City         @relation("CityA", fields: [cityAId], references: [id])
  cityB           City         @relation("CityB", fields: [cityBId], references: [id])
  purpose         String
  buyerEmail      String?
  status          ReportStatus @default(DRAFT)
  accessTokenHash String?      @unique
  snapshot        Json?
  paidAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  payments Payment[]
}

model Payment {
  id                      String   @id @default(cuid())
  reportId                String
  report                  Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  stripeCheckoutSessionId String?  @unique
  stripePaymentIntentId   String?
  amount                  Int
  currency                String   @default("usd")
  status                  String
  buyerEmail              String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}
